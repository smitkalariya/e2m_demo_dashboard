ENVIRONMENT=development

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/e2m
REDIS_URL=redis://localhost:6379/0

JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Leave OPENAI_BASE_URL unset to call OpenAI directly with OPENAI_MODEL=gpt-4o-mini.
# To use OpenRouter instead, set OPENAI_BASE_URL=https://openrouter.ai/api/v1 and
# OPENAI_MODEL=openai/gpt-4o-mini (OpenRouter requires the provider/model prefix).
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=30
OPENAI_MAX_RETRIES=2

CORS_ORIGINS=["http://localhost:3000"]

RATE_LIMIT_PER_MINUTE=120
AUTH_RATE_LIMIT_PER_MINUTE=20
