# URL of the FastAPI backend that Next.js proxies /api/v1/* requests to.
# Requests never leave the Next.js origin from the browser's perspective, so
# the backend's httpOnly auth cookies are set on this app's own domain.
BACKEND_ORIGIN=http://localhost:8000

# TEMPORARY standalone-demo switch. When "true", every src/services/*.service.ts
# uses an in-memory/localStorage-backed mock implementation (src/lib/mock/) instead
# of calling the FastAPI backend — no Postgres/Redis/OpenAI/backend required.
# Auth accepts any email/password. Leave unset/false for real-backend development.
NEXT_PUBLIC_USE_MOCK_API=false
