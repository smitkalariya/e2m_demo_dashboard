# Required by docker-compose.yml. Generate a real secret, e.g.:
#   openssl rand -hex 32
JWT_SECRET_KEY=
# Leave OPENAI_BASE_URL unset for OpenAI directly (OPENAI_MODEL=gpt-4o-mini),
# or set it to https://openrouter.ai/api/v1 with OPENAI_MODEL=openai/gpt-4o-mini
# to route through OpenRouter instead.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini
CORS_ORIGINS=["http://localhost:3000"]
RATE_LIMIT_PER_MINUTE=120
AUTH_RATE_LIMIT_PER_MINUTE=20
